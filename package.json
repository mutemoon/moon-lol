{
  "name": "fsm-demo-rust",
  "scripts": {
    "example": "cargo run --example",
    "extract": "cargo run --example extract",
    "extract:bin": "cargo run --example extract -- --no-mapgeo",
    "fix": "cargo fix --allow-dirty --workspace",
    "format": "cargo +nightly fmt",
    "hot:patch": "dx serve --hot-patch --features \"bevy/hotpatching\"",
    "release": "cargo run --release --example",
    "start": "cargo run",
    "start:all": "docker compose up -d && until docker exec moon-lol-postgres pg_isready -U postgres -d moon_lol 2>/dev/null; do sleep 1; done && pnpm start:server",
    "start:server": "cargo run -p lol_web_server",
    "test": "cargo run --example test",
    "wasm": "cargo build --release --target wasm32-unknown-unknown",
    "wasm:bindgen": "wasm-bindgen --out-name lol --out-dir packages/lol --target web target/wasm32-unknown-unknown/release/examples/lol.wasm",
    "wasm:win": "pnpm wasm && pnpm wasm:bindgen",
    "watch": "cargo watch -- cargo run --example",
    "watch:run": "cargo watch -- cargo run --"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@types/node": "^24.10.3",
    "gltf-pipeline": "^4.3.1",
    "prettier": "^3.7.4",
    "prettier-plugin-package": "^2.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "ts-node": "^10.9.2"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
