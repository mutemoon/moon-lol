{
  "name": "fsm-demo-rust",
  "scripts": {
    "extract": "cargo run --example extract_map_data",
    "extract:ts": "ts-node scripts/extract.ts",
    "fix": "cargo fix --allow-dirty --workspace",
    "format": "cargo +nightly fmt",
    "hot:patch": "dx serve --hot-patch --features \"bevy/hotpatching\"",
    "test:minion:watch": "cargo-watch -w src -x \"test -p moon_lol --test minion -- tests::test_complete_attack_cycle --exact --nocapture\"",
    "test:render": "node scripts/run-render-tests.mjs",
    "test:render:fiora": "cargo test --test fiora_render_test -- --test-threads=1",
    "test:render:riven": "cargo test --test riven_render_test -- --test-threads=1",
    "wasm": "cargo build --release --example lol --target wasm32-unknown-unknown",
    "wasm:bindgen": "wasm-bindgen --out-name lol --out-dir packages/lol --target web target/wasm32-unknown-unknown/release/examples/lol.wasm",
    "wasm:win": "pnpm wasm && pnpm wasm:bindgen",
    "watch": "cargo watch -- cargo run --example"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@types/node": "^24.10.3",
    "gltf-pipeline": "^4.3.1",
    "prettier": "^3.7.4",
    "prettier-plugin-package": "^2.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "ts-node": "^10.9.2"
  }
}
